CXX_STD = CXX17

# Enable C99 format specifiers (%zu, %zd) on MinGW
PKG_CPPFLAGS_WIN = -D__USE_MINGW_ANSI_STDIO=1

# Get ggmlR paths dynamically
GGMLR_INCLUDE = $(shell "$(R_HOME)/bin/Rscript" -e "cat(system.file('include', package='ggmlR'))")
GGMLR_LIB = $(shell "$(R_HOME)/bin/Rscript" -e "cat(system.file('lib', package='ggmlR'))")

PKG_CPPFLAGS = -Isd -Isd/thirdparty \
  -DGGML_USE_CPU -D_GNU_SOURCE \
  -DGGML_MAX_NAME=128 \
  -DGGML_R_PACKAGE -include $(GGMLR_INCLUDE)/r_ggml_compat.h \
  $(PKG_CPPFLAGS_WIN)

PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS)
PKG_CFLAGS = $(SHLIB_OPENMP_CFLAGS)
PKG_LIBS = -L$(GGMLR_LIB) -lggml $(SHLIB_OPENMP_CXXFLAGS) -lpthread -lm

SD_OBJECTS = \
  sd/stable-diffusion.o \
  sd/model.o \
  sd/name_conversion.o \
  sd/tokenize_util.o \
  sd/upscaler.o \
  sd/util.o \
  sd/version.o \
  sd/thirdparty/zip.o

R_INTERFACE_OBJECTS = RcppExports.o sdR_interface.o

OBJECTS = $(R_INTERFACE_OBJECTS) $(SD_OBJECTS)

# R interface files include R headers which conflict with r_ggml_compat.h
# macro redirections. R_GGML_IO_IMPL disables the macros.
RcppExports.o: PKG_CPPFLAGS += -DR_GGML_IO_IMPL
sdR_interface.o: PKG_CPPFLAGS += -DR_GGML_IO_IMPL
